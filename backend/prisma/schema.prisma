generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

model users {
  id         Int       @id @default(autoincrement())
  username   String    @unique(map: "username") @db.VarChar(50)
  email      String    @unique(map: "email") @db.VarChar(255)
  birth_date DateTime  @db.Date
  password   String    @db.VarChar(255)
  created_at DateTime? @default(now()) @db.Timestamp(0)

  lists         lists[]
  assessments   assessments[]
  notifications notifications[]
}

model games {
  id            Int       @id @default(autoincrement())
  cheapshark_id String    @unique @db.VarChar(50)
  titulo        String    @db.VarChar(255)
  imagem_url    String?   @db.VarChar(500)
  preco_atual   Decimal?  @db.Decimal(10, 2)
  menor_preco   Decimal?  @db.Decimal(10, 2)
  loja          String?   @db.VarChar(100)
  created_at    DateTime? @default(now()) @db.Timestamp(0)
  updated_at    DateTime  @updatedAt

  lists         lists[]
  assessments   assessments[]
  promos        promos[]
  notifications notifications[]
}

enum TipoLista {
  desejados
  nao_jogados
  jogados
  jogar_novamente
  backlog
  favoritos
}

model lists {
  id         Int       @id @default(autoincrement())
  usuario_id Int
  jogo_id    Int
  tipo_lista TipoLista
  prioridade Int             @default(1)
  status     BacklogStatus  @default(quer_jogar)
  added_at   DateTime?      @default(now()) @db.Timestamp(0)

  usuario users @relation(fields: [usuario_id], references: [id], onDelete: Cascade)
  jogo    games @relation(fields: [jogo_id], references: [id], onDelete: Cascade)

  @@unique([usuario_id, jogo_id])
}

enum BacklogStatus {
  quer_jogar
  joguei
  talvez
}

model assessments {
  id             Int       @id @default(autoincrement())
  usuario_id     Int
  jogo_id        Int
  nota           Int
  comentario     String?   @db.VarChar(500)
  data_avaliacao DateTime? @default(now()) @db.Timestamp(0)

  usuario users @relation(fields: [usuario_id], references: [id], onDelete: Cascade)
  jogo    games @relation(fields: [jogo_id], references: [id], onDelete: Cascade)

  @@unique([usuario_id, jogo_id])
}

model promos {
  id                Int       @id @default(autoincrement())
  jogo_id           Int
  preco_promocional Decimal   @db.Decimal(10, 2)
  preco_normal      Decimal?  @db.Decimal(10, 2)
  loja              String?   @db.VarChar(100)
  deal_id           String?   @db.VarChar(100)
  data_inicio       DateTime? @default(now()) @db.Timestamp(0)
  data_fim          DateTime? @db.Timestamp(0)

  jogo games @relation(fields: [jogo_id], references: [id], onDelete: Cascade)
}

model notifications {
  id         Int       @id @default(autoincrement())
  usuario_id Int
  jogo_id    Int
  mensagem   String    @db.VarChar(255)
  lida       Boolean   @default(false)
  data_envio DateTime? @default(now()) @db.Timestamp(0)

  usuario users @relation(fields: [usuario_id], references: [id], onDelete: Cascade)
  jogo    games @relation(fields: [jogo_id], references: [id], onDelete: Cascade)
}
